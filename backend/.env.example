# ==============================================================================
# BHASKAR Startup India - Environment Configuration Template
# ==============================================================================

# Server Environment Configuration
PORT=5000
NODE_ENV=production

# Database Connection (MongoDB)
# In production, replace this with your secure atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.example.mongodb.net/bhaskar?retryWrites=true&w=major

# Security (JWT Session Management)
# IMPORTANT: Generate a strong, unique 32+ character random hex string for JWT_SECRET
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=2h

# CORS Allowed Clients (Comma-separated origins, no trailing slashes)
CLIENT_ORIGIN=https://bhaskar-startup.gov.in
OTP_TTL_MINUTES=10

# Administrator Credentials
# IMPORTANT: Must be changed from defaults and be at least 12 characters in production
ADMIN_EMAIL=admin@startupindia.gov.in
ADMIN_PASSWORD=replace-with-a-strong-admin-password-at-least-12-chars

# Email Service Configuration (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-secure-password
SMTP_FROM=BHASKAR Startup India <no-reply@startupindia.gov.in>
SMTP_SECURE=false

# Media Storage Configuration (Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_UPLOAD_FOLDER=bhaskar-startup-india/logos
