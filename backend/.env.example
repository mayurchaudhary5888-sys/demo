PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/bhaskar_startup_india
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=2h
# Comma-separate exact frontend origins when needed, without trailing slashes.
CLIENT_ORIGIN=http://localhost:3000
OTP_TTL_MINUTES=10
ADMIN_EMAIL=admin@startupindia.gov.in
ADMIN_PASSWORD=replace-with-a-strong-admin-password
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=BHASKAR Startup India <no-reply@startupindia.gov.in>
SMTP_SECURE=false

# Cloudinary logo/image storage. Keep API secret only on backend.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=bhaskar-startup-india/logos
